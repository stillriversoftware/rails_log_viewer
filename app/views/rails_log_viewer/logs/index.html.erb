<div id="rlv-app"
     data-source="<%= @source %>"
     data-streams="<%= @streams.to_json %>"
     data-files="<%= @files.to_json %>"
     data-query-url="<%= query_path %>"
     data-stream-url="<%= stream_path %>">

  <header id="rlv-header">
    <div id="rlv-header-left">
      <h1 id="rlv-title">Log Viewer</h1>
      <span id="rlv-source-badge"><%= @source.to_s.capitalize %></span>
    </div>
    <div id="rlv-header-right">
      <% if @source == :cloudwatch %>
        <select id="rlv-stream-select" aria-label="Log stream">
          <option value="">All streams</option>
          <% @streams.each do |stream| %>
            <option value="<%= stream %>"><%= stream %></option>
          <% end %>
        </select>
      <% end %>
      <% if @source == :s3 %>
        <select id="rlv-file-select" aria-label="Log file">
          <option value="">Select log file...</option>
          <% @files.each do |file| %>
            <option value="<%= file[:key] %>"><%= file[:name] %></option>
          <% end %>
        </select>
      <% end %>

      <div id="rlv-time-controls">
        <select id="rlv-time-range" aria-label="Time range">
          <option value="15m">Last 15 min</option>
          <option value="1h" selected>Last 1 hour</option>
          <option value="6h">Last 6 hours</option>
          <option value="24h">Last 24 hours</option>
          <option value="custom">Custom...</option>
        </select>
        <div id="rlv-custom-time" hidden>
          <input type="datetime-local" id="rlv-time-start" aria-label="Start time">
          <span id="rlv-time-sep">to</span>
          <input type="datetime-local" id="rlv-time-end" aria-label="End time">
          <button id="rlv-time-apply" type="button">Apply</button>
        </div>
      </div>

      <div id="rlv-severity-controls">
        <button type="button" class="rlv-sev-btn rlv-sev-active" data-severity="ERROR">ERR</button>
        <button type="button" class="rlv-sev-btn rlv-sev-active" data-severity="WARN">WRN</button>
        <button type="button" class="rlv-sev-btn rlv-sev-active" data-severity="INFO">INF</button>
        <button type="button" class="rlv-sev-btn" data-severity="DEBUG">DBG</button>
      </div>

      <div id="rlv-search-wrap">
        <input type="text"
               id="rlv-search"
               placeholder="Search logs..."
               autocomplete="off"
               spellcheck="false"
               aria-label="Search logs">
      </div>

      <button id="rlv-live-btn" type="button" aria-pressed="false">Live Tail</button>
      <button id="rlv-copy-btn" type="button">Copy</button>
    </div>
  </header>

  <main id="rlv-output-wrap">
    <div id="rlv-output" role="log" aria-live="polite"></div>
    <div id="rlv-status" hidden></div>
    <button id="rlv-jump-latest" type="button" hidden>New logs available</button>
  </main>

  <footer id="rlv-footer">
    <button id="rlv-older-btn" type="button" hidden>Load older logs</button>
  </footer>
</div>
